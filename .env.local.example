# Database
PGHOST=localhost
PGPORT=5432
PGDATABASE=hairrdv
PGUSER=postgres
PGPASSWORD=postgres

# JWT — change this in production!
JWT_SECRET=change-me-to-a-long-random-string

# IP Hashing salt — change this in production!
IP_HASH_SALT=change-me-to-another-random-string

# ─── Public salon info (the ONLY place to put salon text) ───────────────────
NEXT_PUBLIC_SALON_NAME=Mon Salon de Coiffure
NEXT_PUBLIC_SALON_ADDRESS=123 Rue de la Beauté, 75001 Paris
NEXT_PUBLIC_SALON_PHONE=+33 1 23 45 67 89
NEXT_PUBLIC_SALON_EMAIL=contact@monsalon.fr

# Comma-separated list of services offered
NEXT_PUBLIC_SERVICES=Coupe Femme,Coupe Homme,Coloration,Mèches,Lissage,Brushing,Soin,Permanente

# Opening hours (HH:MM, 24h format)
NEXT_PUBLIC_OPENING_START=09:00
NEXT_PUBLIC_OPENING_END=19:00

# Base URL (for confirmation email links)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Email (Resend) — optional, falls back to console.log
RESEND_API_KEY=re_xxxxxxxxxxxxx
EMAIL_FROM=noreply@tondomaine.com

# No-show threshold before auto-blacklist
NO_SHOW_THRESHOLD=3

# Pour accès réseau local (Tailscale, Wi-Fi)
# Démarrer avec : npm run dev
# Puis accéder via http://<IP-Tailscale>:3000
